{
  "name": "marketplace",
  "version": "1.0.8",
  "private": true,
  "homepage": "https://github.com/spicetify/marketplace",
  "bugs": {
    "url": "https://github.com/spicetify/marketplace/issues"
  },
  "repository": "github:spicetify/marketplace",
  "scripts": {
    "sc": "spicetify-creator",
    "dev": "spicetify-creator dev",
    "build": "spicetify-creator build",
    "update-types": "spicetify-creator update-types",
    "build:prod": "pnpm run build && pnpm copy:docs",
    "copy:docs": "copyfiles README.md dist/",
    "fmt": "oxfmt",
    "lint": "oxlint --fix ./src",
    "lint:ci": "oxlint",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "chroma-js": "^3.2.0",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "prismjs": "^1.30.0",
    "react-dropdown": "^1.11.0",
    "react-i18next": "^16.5.0",
    "react-simple-code-editor": "^0.14.1",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@spicetify/creator": "^1.0.0",
    "@types/chroma-js": "^3.1.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/semver": "^7.7.1",
    "@types/wicg-file-system-access": "^2023.10.7",
    "copyfiles": "^2.4.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "npm": "please-use-pnpm",
    "pnpm": ">=8",
    "yarn": "please-use-pnpm"
  },
  "packageManager": "pnpm@9.0.6"
}
